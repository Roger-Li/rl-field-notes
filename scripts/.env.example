# TTS model comparison API keys
# Copy this file to scripts/.env and fill in the keys you have.
# Models with missing keys are skipped automatically.

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Fish Audio — https://fish.audio → API settings
FISH_AUDIO_API_KEY=

# SiliconFlow (hosts CosyVoice2) — https://cloud.siliconflow.cn
SILICONFLOW_API_KEY=

# MiniMax — https://platform.minimax.io
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# MiMo (Xiaomi) — https://platform.xiaomimimo.com
MIMO_API_KEY=
