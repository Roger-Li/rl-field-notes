{
  "name": "rl-field-notes",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "generate-audio": "node scripts/generate-audio.mjs",
    "validate-content": "node scripts/validate-content.mjs",
    "video:infant-experiments:figures": "node scripts/render-infant-experiments-figures.mjs --output-dir video/infant-experiments/flagship-en/assets/article-figures",
    "video:infant-experiments:prepare": "bash video/infant-experiments/flagship-en/prepare-assets.sh",
    "video:infant-experiments:audio": "bash video/infant-experiments/flagship-en/render-audio.sh",
    "video:infant-experiments:overlays": "node scripts/render-overlay-pngs.mjs --bundle video/infant-experiments/flagship-en",
    "video:infant-experiments:assemble": "node scripts/assemble-video.mjs --bundle video/infant-experiments/flagship-en",
    "video:infant-experiments:thumbnail": "node scripts/render-thumbnail.mjs --bundle video/infant-experiments/flagship-en",
    "video:infant-experiments:retime": "node scripts/retime-shotlist.mjs --bundle video/infant-experiments/flagship-en",
    "video:infant-experiments:render": "npm run video:infant-experiments:overlays && npm run video:infant-experiments:assemble && npm run video:infant-experiments:thumbnail"
  },
  "dependencies": {
    "@giscus/react": "^3.1.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.1.6",
    "@tailwindcss/typography": "^0.5.19",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
